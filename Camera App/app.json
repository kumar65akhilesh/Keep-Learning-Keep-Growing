{
  "expo": {
    "name": "Little Letters",
    "slug": "camera-ocr-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "camera-ocr-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#1A1A2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.letterlens.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Little Letters needs camera access to recognize letters and numbers.",
        "NSSpeechRecognitionUsageDescription": "Little Letters uses speech to read recognized characters aloud."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFD60A"
      },
      "package": "com.letterlens.app",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Little Letters needs camera access to recognize letters and numbers.",
          "enableFrameProcessors": true
        }
      ],
      "react-native-fast-tflite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
